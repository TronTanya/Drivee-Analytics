APP_NAME=Drivee Analytics Notebook API
APP_ENV=dev
APP_VERSION=0.1.0
DEBUG=false
API_V1_PREFIX=/api/v1

# CORS_ORIGINS поддерживает и CSV, и JSON-массив:
# - http://localhost:3000,http://localhost:3001
# - ["http://localhost:3000","http://localhost:3001"]
# 3001 — если фронт на FRONTEND_PORT=3001 (конфликт с занятым :3000)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

JWT_SECRET=change_me
JWT_REFRESH_SECRET=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXP_MINUTES=60
REFRESH_TOKEN_EXP_DAYS=7

POSTGRES_HOST=localhost
POSTGRES_PORT=55432
POSTGRES_DB=drivee_analytics
POSTGRES_USER=drivee
POSTGRES_PASSWORD=drivee
DATABASE_URL=postgresql+psycopg2://drivee:drivee@localhost:55432/drivee_analytics
DB_ECHO=false
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# false: выполнять SQL в PostgreSQL (MVP E2E). true: только stub-строки без БД (офлайн / CI без БД).
MOCK_MODE=false
# При MOCK_MODE=false: если true — при ошибке Postgres в execute вернуть stub-строки и предупреждение (не для продакшена).
MOCK_SQL_EXECUTION_FALLBACK=false
SQL_DEFAULT_LIMIT=1000
SQL_TIMEOUT_SECONDS=8
# Доверие к SQL: запрет SELECT * вне MOCK_MODE; глобальный whitelist колонок; intent с обязательным LIMIT.
SQL_FORBID_SELECT_STAR=true
SQL_ENFORCE_GLOBAL_COLUMN_WHITELIST=true
# Разрешённые схемы для физических таблиц в FROM/JOIN (через запятой или JSON-массив).
SQL_WHITELIST_SCHEMAS=public,user_staging
SQL_IMPLICIT_SCHEMA=public
# Имена загруженных CSV-таблиц в csv_staging_schema (см. csv_workflow).
SQL_STAGING_UPLOAD_TABLE_PATTERN=^t_[a-f0-9]{12}$
# Guardrails NL→SQL
GUARDRAILS_MAX_PROMPT_CHARS=8000
GUARDRAILS_MAX_PROMPT_NEWLINES=80
GUARDRAILS_RATE_LIMIT_ENABLED=true
GUARDRAILS_RATE_LIMIT_WINDOW_SECONDS=60
GUARDRAILS_MAX_REQUESTS_PER_WINDOW=40
# Производительность SQL (период, GROUP BY, sample LIMIT, кэш результатов).
SQL_WARN_SCAN_PERIOD_DAYS=90
SQL_HARD_SCAN_PERIOD_DAYS=730
SQL_WARN_GROUP_BY_COLUMNS=5
SQL_SLOW_QUERY_COMPLEXITY_SCORE=50
SQL_SAMPLE_COMPLEXITY_SCORE_MIN=55
SQL_SAMPLE_MAX_ROWS=300
SQL_EXECUTION_HARD_ROW_CAP=5000
SQL_RESULT_CACHE_ENABLED=true
SQL_RESULT_CACHE_TTL_SECONDS=60
SQL_RESULT_CACHE_MAX_ENTRIES=200
DICTIONARY_API_CACHE_TTL_SECONDS=120
TEMPLATE_QUICK_RUN_CACHE_TTL_SECONDS=90
# JSON-массив intent (опционально), иначе дефолт в коде.
# SQL_INTENTS_REQUIRE_LIMIT=["ranking","geo","comparison","share","trend","forecast"]
DS_DEFAULT_SOURCE_TABLE=public.train
# false: без явного source_table в контексте notebook всегда DS_DEFAULT_SOURCE_TABLE (канонический train).
# true: подставлять последнюю успешную staging-таблицу из импорта CSV (может расходиться с «всё из train»).
DS_IMPLICIT_SOURCE_USE_LATEST_STAGING=false
DS_METRIC_CAPS={"orders_count":10000000,"done_rides":10000000,"cancellations_total":10000000,"sum_order_price":1000000000}

# LLM: поддерживается только LLM_PROVIDER=deepseek (иначе слой LLM отключён без ошибки при старте).
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
LLM_TIMEOUT_SECONDS=45
LLM_TEMPERATURE=0.1
# JSON-интент/инсайты; при обрезании ответа увеличьте.
LLM_MAX_TOKENS=1024
# Circuit breaker в LLMService: столько подряд ошибок парсинга/сети → пауза LLM_COOLDOWN_SECONDS.
LLM_FAILURE_THRESHOLD=3
LLM_COOLDOWN_SECONDS=45
