APP_NAME=Drivee Analytics Notebook API
APP_ENV=dev
APP_VERSION=0.1.0
DEBUG=false
API_V1_PREFIX=/api/v1

CORS_ORIGINS=http://localhost:3000

JWT_SECRET=change_me
JWT_REFRESH_SECRET=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXP_MINUTES=60
REFRESH_TOKEN_EXP_DAYS=7

POSTGRES_HOST=localhost
POSTGRES_PORT=55432
POSTGRES_DB=drivee_analytics
POSTGRES_USER=drivee
POSTGRES_PASSWORD=drivee
DATABASE_URL=postgresql+psycopg2://drivee:drivee@localhost:55432/drivee_analytics
DB_ECHO=false
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

MOCK_MODE=true
SQL_DEFAULT_LIMIT=1000
SQL_TIMEOUT_SECONDS=8
DS_DEFAULT_SOURCE_TABLE=public.anonymized_incity_orders
DS_METRIC_CAPS={"orders_count":10000000,"done_rides":10000000,"cancellations_total":10000000,"sum_order_price":1000000000}
CITY_ID_LABEL_MAP={"67":"Алматы"}

LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
LLM_TIMEOUT_SECONDS=12
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=500
