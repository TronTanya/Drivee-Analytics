# same-origin — fetch на /api/* через Next rewrites (рекомендуется в Docker). Иначе полный URL бэкенда.
NEXT_PUBLIC_API_URL=same-origin
# Только для локального npm run dev, если бэкенд не на 8000:
# API_PROXY_TARGET=http://127.0.0.1:8000
# INTERNAL_API_URL=http://127.0.0.1:8000
NEXT_PUBLIC_API_MOCK=false

# --- Защита / демо (подробно: docs/demo-defense.md) ---
# NEXT_PUBLIC_DEMO_MODE=true
# NEXT_PUBLIC_API_MOCK=fallback
# Честный live analytics: НЕ задавать или false. Для полного офлайна аналитики:
# NEXT_PUBLIC_DEMO_FORCE_ANALYTICS_MOCK=true
