# Docker Compose variables
COMPOSE_PROJECT_NAME=drivee

# Ports exposed on host
FRONTEND_PORT=3000
BACKEND_PORT=8000
POSTGRES_PORT=5432
PGADMIN_PORT=5050

# Postgres
POSTGRES_DB=drivee_analytics
POSTGRES_USER=drivee
POSTGRES_PASSWORD=drivee

# Backend runtime
BACKEND_CORS_ORIGINS=http://localhost:3000

# Frontend runtime (в браузере: хост и порт должны совпадать с BACKEND_PORT, см. docker-compose)
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_API_MOCK=false

# Optional pgAdmin
PGADMIN_DEFAULT_EMAIL=admin@drivee.local
PGADMIN_DEFAULT_PASSWORD=admin
