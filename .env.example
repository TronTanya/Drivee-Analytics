# Docker Compose variables
COMPOSE_PROJECT_NAME=drivee

# Ports exposed on host
FRONTEND_PORT=3000
BACKEND_PORT=8000
POSTGRES_PORT=5432
PGADMIN_PORT=5050

# Postgres
POSTGRES_DB=drivee_analytics
POSTGRES_USER=drivee
POSTGRES_PASSWORD=drivee

# Backend runtime
# Соответствует портам фронта (3001 — типичный обход занятого :3000 на хосте)
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Frontend: в Docker по умолчанию same-origin + прокси на сервис backend (см. docker-compose) — без CORS в браузере.
# Прямой вызов бэкенда с хоста: NEXT_PUBLIC_API_URL=http://localhost:8000 (нужен корректный CORS_ORIGINS / BACKEND_CORS_ORIGINS).
NEXT_PUBLIC_API_URL=same-origin
NEXT_PUBLIC_API_MOCK=false

# Optional pgAdmin
PGADMIN_DEFAULT_EMAIL=admin@drivee.local
PGADMIN_DEFAULT_PASSWORD=admin

# Импорт train при старте backend (docker-compose подставляет в command; -1 = весь файл)
# EXTERNAL_TRAIN_CSV_LIMIT=-1
# SKIP_DEMO_TRAIN_SEED=true
